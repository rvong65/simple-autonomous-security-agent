# Copy to Streamlit Cloud Secrets (Settings → Secrets in the deployed app).
# For local Streamlit testing, copy to .streamlit/secrets.toml (gitignored).

DEPLOYMENT_PROFILE = "cloud"
LLM_PROVIDER = "groq"
LLM_MODEL = "llama-3.1-8b-instant"
GROQ_API_KEY = "gsk_your_key_here"

# Optional: live IP reputation via AbuseIPDB
# ABUSEIPDB_API_KEY = "your_abuseipdb_key"

# ── Ollama (local alternative — use .env instead of secrets.toml) ─────────────
# DEPLOYMENT_PROFILE = "local"
# LLM_PROVIDER = "ollama"
# LLM_MODEL = "gemma3:4b"
# OLLAMA_BASE_URL = "http://localhost:11434"
