# SASA environment configuration
# Copy to .env and fill in your API key:
#   cp .env.example .env
#
# Two LLM options:
#   • Groq (cloud) — recommended for deployment; free tier at console.groq.com
#   • Ollama (local) — uncomment the Ollama block below and comment out Groq

# ── Groq (default — matches Streamlit Cloud deployment) ──────────────────────
DEPLOYMENT_PROFILE=cloud
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Required for Groq. Never commit a real key — keep .env in .gitignore.
GROQ_API_KEY=

# ── Ollama (local alternative) ─────────────────────────────────────────────────
# DEPLOYMENT_PROFILE=local
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Optional ───────────────────────────────────────────────────────────────────
# Together: fallback cloud provider if Groq is unavailable (LLM_PROVIDER=together)
TOGETHER_API_KEY=
ABUSEIPDB_API_KEY=

# Agent limits
MAX_AGENT_STEPS=8
MAX_TOOL_CALLS_PER_INVESTIGATION=10
TOOL_TIMEOUT_SECONDS=5
LLM_TIMEOUT_SECONDS=30
